{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://3.108.155.142:8080/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://3.108.155.142:8080/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
