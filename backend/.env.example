# Backend Environment Variables

# MongoDB Connection URI
# Local: mongodb://localhost:27017/foodbank
# Remote Server: mongodb://3.108.155.142:27017/foodbank
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/foodbank
MONGODB_URI=mongodb://localhost:27017/foodbank

# AI Services URL (internal - for Railway/Docker, use http://ai-services:5001)
# Remote Server: http://3.108.155.142:5001
AI_BASE_URL=http://localhost:5001

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET=SmartFoodBank2024_SuperSecretKey

# Server Port
PORT=8080

# Node Environment
NODE_ENV=development

# ────── Cloudinary (for file uploads) ──────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ────── CORS Configuration ──────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-frontend.vercel.app

